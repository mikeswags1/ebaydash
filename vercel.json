{
  "functions": {
    "app/api/ebay/list-product/route.ts": {
      "maxDuration": 60
    },
    "app/api/cron/refresh-products/route.ts": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/cron/refresh-products?catalog=1",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/refresh-products?sourceOnly=1",
      "schedule": "0 */6 * * *"
    }
  ]
}
