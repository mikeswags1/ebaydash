## StackPilot (EbayDash) environment variables
## Copy to `.env.local` for development.
##
## Required for database + auth + integrations:
## - DATABASE_URL is required for all auth + persistence
## - NEXTAUTH_SECRET is required for NextAuth JWT signing
## - NEXTAUTH_URL should match your deployed URL (or http://localhost:3000)
##
## Optional keys enable additional features (OAuth, AI, sourcing).

## Database (Neon Postgres)
DATABASE_URL=

## NextAuth
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

## Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

## eBay OAuth / API
EBAY_APP_ID=
EBAY_CERT_ID=
EBAY_DEV_ID=
EBAY_RUNAME=
EBAY_ITEM_LOCATION=New Jersey, United States
EBAY_POSTAL_CODE=07001

## Amazon SP-API OAuth (optional; Amazon connection UI is currently removed)
AMAZON_APP_ID=
AMAZON_REDIRECT_URI=
AMAZON_CLIENT_ID=
AMAZON_CLIENT_SECRET=

## RapidAPI (Amazon sourcing / lookup)
RAPIDAPI_KEY=

## OpenRouter (AI helper)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

## Cron protection (recommended in production)
CRON_SECRET=

## Billing — treat these accounts as Pro without Stripe (product owner / staff)
# Comma-separated numeric user ids from the users table, e.g. 1,4
STACKPILOT_OWNER_USER_IDS=
# Or comma-separated emails (matched case-insensitively), e.g. you@domain.com
STACKPILOT_OWNER_EMAILS=

